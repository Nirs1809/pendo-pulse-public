# Pendo Integration Key (server-only, never prefix with NEXT_PUBLIC_)
# Create one in Pendo: Settings → Integrations → Integration Keys
# The key only needs READ scope.
PENDO_INTEGRATION_KEY=

# Pendo API base. Default is the US datacenter. Change for EU/US2:
#   US   (default):  https://app.pendo.io/api/v1
#   EU:              https://app.eu.pendo.io/api/v1
#   US2:             https://us2.pendo.io/api/v1
PENDO_API_BASE=https://app.pendo.io/api/v1

# The subscription & dashboard to mirror. The defaults point to the
# Pulse dashboard that was used to scaffold this project.
PENDO_SUBSCRIPTION_ID=5389416346288128
PENDO_DEFAULT_DASHBOARD_ID=GP7dJrlLrK47XJGWRZkf6WkJjWM

# The Pendo app ID to scope every widget to. Default is Pulse
# (host: pulse.pendoexperience.io). Visitor metadata in Pendo is stored
# under `metadata.auto_<appId>.*` — swap this ID to filter the whole
# dashboard to a different app.
PENDO_APP_ID=6561780136607744
